# Postgres — Railway provides this automatically in production
DATABASE_URL=postgresql://user:password@localhost:5432/routefinder

# Backblaze B2
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=routefinder-images
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
HF_TOKEN=your_hf_token

# Model — set after training
MODEL_CHECKPOINT=
MODEL_VERSION=v1
